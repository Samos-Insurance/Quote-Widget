{
  "name": "quote-widget",
  "version": "1.0.1",
  "description": "Embedded quote widget",
  "main": "dist/npm/widget.js",
  "types": "dist/npm/quote-widget.d.ts",
  "scripts": {
    "dev": "next dev -p 5000",
    "build:types": "tsc -p tsconfig.widget.json",
    "build:js-prod": "cross-env BUILD_ENV=prod node build.js",
    "build:js-test": "cross-env BASE_URL=https://example.com BUILD_ENV=dev node build.js",
    "build:js-dev": "cross-env BUILD_ENV=dev node build.js",
    "build:prod": "npm run build:types && npm run build:js-prod",
    "build:dev": "npm run build:types && npm run build:js-dev",
    "build:test": "npm run build:types && npm run build:js-test",
    "start": "next start -p 5000",
    "lint": "eslint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Samos-Insurance/Quote-Widget.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "serverless": "^3.40.0",
    "serverless-s3-sync": "^3.5.1",
    "serverless-webpack": "^5.15.4",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}